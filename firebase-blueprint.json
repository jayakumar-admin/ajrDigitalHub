{
  "entities": {
    "Theme": {
      "title": "Theme",
      "description": "A website template available for purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "previewUrl": { "type": "string" },
        "price": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "demoUrl": { "type": "string" }
      },
      "required": ["id", "name", "category", "previewUrl", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "An order request submitted by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "businessName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "themeId": { "type": "string" },
              "themeName": { "type": "string" },
              "planName": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "businessName", "phone", "email", "items", "totalPrice", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user account, typically a shop owner.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "shop_owner"] },
        "shopName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "gstDetails": { "type": "string" },
        "address": { "type": "string" },
        "contactInfo": { "type": "string" },
        "subscriptionPlanId": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive", "cancelled"] },
        "invoicesGeneratedThisMonth": { "type": "number" },
        "subscriptionValidUntil": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "SubscriptionPlan": {
      "title": "SubscriptionPlan",
      "description": "A SaaS subscription plan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "invoiceLimit": { "type": "number" },
        "themeLimit": { "type": "number" },
        "priceMonthly": { "type": "number" },
        "priceYearly": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "invoiceLimit", "themeLimit", "priceMonthly", "priceYearly"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "An invoice generated by a shop owner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopOwnerUid": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerAddress": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "taxRate": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "taxTotal": { "type": "number" },
        "total": { "type": "number" },
        "themeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shopOwnerUid", "customerName", "items", "subtotal", "taxTotal", "total", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product managed by a shop owner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopOwnerUid": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "taxRate": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["id", "shopOwnerUid", "name", "price"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer managed by a shop owner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopOwnerUid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["id", "shopOwnerUid", "name"]
    },
    "InvoiceTheme": {
      "title": "InvoiceTheme",
      "description": "A theme for generating invoices.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "previewUrl": { "type": "string" },
        "cssVariables": { "type": "object" }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "/themes/{themeId}": {
      "schema": "Theme",
      "description": "Collection of available website themes."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of user order requests."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user accounts."
    },
    "/subscriptionPlans/{planId}": {
      "schema": "SubscriptionPlan",
      "description": "Collection of available subscription plans."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of generated invoices."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products managed by shop owners."
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of customers managed by shop owners."
    },
    "/invoiceThemes/{themeId}": {
      "schema": "InvoiceTheme",
      "description": "Collection of invoice themes."
    }
  }
}

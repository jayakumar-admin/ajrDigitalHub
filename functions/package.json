{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "prestart": "npm run build",
    "dev": "nodemon",
    "build": "npx esbuild src/app.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/server.js --external:express --external:axios --external:firebase-admin --external:@prisma/client",
    "gcp-build": "",
    "lint": "eslint src/**/*.ts",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "24"
  },
  "main": "index.js",
  "dependencies": {
    "axios": "^1.18.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.1.1",
    "firebase-functions": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "puppeteer": "^25.1.0",
    "uuid": "^10.0.0",
    "busboy": "^1.6.0",
    "google-auth-library": "^9.15.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "firebase-functions-test": "^3.4.1",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "@types/busboy": "^1.5.4"
  }
}
